# Canonical gating constants for Gofer ML pipeline v3.
# Keep in sync with cmd/gofer/gating.go (PromoteMin).
# PROMOTE_WIN: head-to-head win rate the candidate must clear to replace the
# champion (also requires Wilson CI low > 0.5). There is NO win-target stop.
PROMOTE_WIN=0.55
PROMOTE_MIN=0.55
ARENA_GAMES=200
# SELFPLAY_PLAYOUTS is the legacy name for the full-search cap (same as SELFPLAY_FULL_PLAYOUTS).
# Self-play draws a per-move cap: fast (cheap) most moves, full (this value) on a random fraction.
# Only full-search positions are exported when train-loop passes -full-only=true.
SELFPLAY_PLAYOUTS=200
SELFPLAY_FULL_PLAYOUTS=200
SELFPLAY_FAST_PLAYOUTS=50
SELFPLAY_CAP_RANDOMIZE_P=0.20
ARENA_PLAYOUTS=400
# hold = run arena but never install candidate (scoring investigation); normal = auto-promote
GATING_MODE=normal
